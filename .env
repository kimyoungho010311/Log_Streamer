# 과제 제출에 용이하게 하기 위해서 .env 파일도 깃에 올라가도록 설정합니다.

# ==============================================================================
# 1. 포트폴리오 메인 데이터베이스 설정 (PostgreSQL)
# ==============================================================================
DB_HOST=postgres-db
DB_PORT=5432
DB_NAME=liveklass_db
DB_USER=admin
DB_PASSWORD=admin

# ==============================================================================
# 2. Apache Airflow 메인 오케스트레이션 설정
# ==============================================================================
AIRFLOW_IMAGE_NAME=liveklass_airflow:custom-2.7.2
AIRFLOW_UID=50000

# ==============================================================================
# 3. 데이터 레이크 및 AWS S3 가상 경로 설정 (3일차 빌드업용)
# ==============================================================================
# 로컬 개발 환경용 가상 데이터 레이크 경로
S3_VIRTUAL_PATH=/opt/airflow/s3_data_lake